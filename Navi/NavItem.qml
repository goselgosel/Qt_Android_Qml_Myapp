
import QtQuick 6.5
import QtQuick.Controls 6.5
// NavItem.qml

// Rectangle: 单个导航项的容器
Rectangle {
    id: navItem         // 组件ID
    color: "transparent" // 透明背景

    /**************************************************************
     * 自定义属性
     **************************************************************/

    // iconText: 图标文本（表情符号）
    // 类型：string（字符串）
    property string iconText: "📱"

    // label: 标签文本
    // 类型：string（字符串）
    property string label: "标签"

    // isActive: 是否处于激活（选中）状态
    // 类型：bool（布尔值）
    property bool isActive: false

    // signal: 定义点击信号
    // 当导航项被点击时发出此信号
    signal clicked()

    /**************************************************************
     * 鼠标点击区域
     **************************************************************/
    // MouseArea: 鼠标/触摸事件处理区域
    MouseArea {
        anchors.fill: parent  // 填充整个导航项

        // cursorShape: 鼠标悬停时的光标形状
        // Qt.PointingHandCursor: 手型指针（表示可点击）
        cursorShape: Qt.PointingHandCursor

        // onClicked: 鼠标点击事件处理器
        onClicked: {
            // 发出clicked信号
            navItem.clicked()
        }
    }

    /**************************************************************
     * 内容布局：图标 + 标签
     **************************************************************/
    // Column: 垂直布局容器
    // 功能：将子项垂直排列
    Column {
        anchors.centerIn: parent  // 在父容器中居中
        spacing: 5               // 子项之间的垂直间距

        /**************************************************************
         * 图标
         **************************************************************/
        Text {
            // 显示图标文本
            text: navItem.iconText

            // 字体大小
            font.pixelSize: 24

            // 根据激活状态设置颜色
            // 激活：微信绿色(#07C160)，未激活：灰色(#999999)
            color: navItem.isActive ? "#07C160" : "#999999"

            /**************************************************************
             * Behavior: 属性行为动画
             **************************************************************/
            // 功能：为color属性添加过渡动画
            Behavior on color {
                // ColorAnimation: 颜色过渡动画
                ColorAnimation {
                    duration: 200  // 动画持续时间200毫秒
                }
            }
        }

        /**************************************************************
         * 标签文本
         **************************************************************/
        Text {
            // 显示标签文本
            text: navItem.label

            // 字体大小
            font.pixelSize: 12

            // 根据激活状态设置颜色
            color: navItem.isActive ? "#07C160" : "#999999"

            // 为color属性添加过渡动画
            Behavior on color {
                ColorAnimation {
                    duration: 200  // 动画持续时间200毫秒
                }
            }
        }
    }

    /**************************************************************
     * 选中指示点
     **************************************************************/
    // 功能：在导航项被选中时显示一个小圆点
    Rectangle {
        width: 6        // 宽度
        height: 6       // 高度
        radius: 3       // 圆角半径（宽度/2 = 圆形）
        color: "#07C160" // 微信绿色

        // visible: 是否可见
        // 仅在激活状态时显示
        visible: navItem.isActive

        /**************************************************************
         * 锚点定位
         **************************************************************/
        anchors {
            // 水平居中
            horizontalCenter: parent.horizontalCenter

            // 底部，距离底部5像素
            bottom: parent.bottom
            bottomMargin: 5
        }

        /**************************************************************
         * 动画效果属性
         **************************************************************/
        // opacity: 透明度（0.0-1.0）
        // 激活时完全不透明，未激活时完全透明
        opacity: navItem.isActive ? 1 : 0

        // scale: 缩放比例
        // 激活时正常大小，未激活时缩小一半
        scale: navItem.isActive ? 1 : 0.5

        /**************************************************************
         * 透明度过渡动画
         **************************************************************/
        Behavior on opacity {
            // NumberAnimation: 数值过渡动画
            NumberAnimation {
                duration: 200  // 动画持续时间200毫秒
            }
        }

        /**************************************************************
         * 缩放过渡动画
         **************************************************************/
        Behavior on scale {
            NumberAnimation {
                duration: 200  // 动画持续时间200毫秒

                // easing.type: 缓动函数类型
                // Easing.OutBack: 回弹效果
                easing.type: Easing.OutBack
            }
        }
    }
}
