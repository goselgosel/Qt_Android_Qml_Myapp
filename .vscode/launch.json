            "environment": [
                {
                    "name": "PATH",
                    "value": "E:/Qt/Qt/6.8.3/mingw_64/bin;E:/Qt/Qt/Tools/mingw1310_64/bin;${env:PATH}"
                }
            ]
        }
    ]
}